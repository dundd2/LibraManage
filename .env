# Database settings
DB_PATH=library.db
POOL_SIZE=5

# Security settings
PASSWORD_SALT=MY_SUPER_SECRET_SALT_123!@#$%^&*
JWT_SECRET=MY_SUPER_SECRET_JWT_456!@#$%^&*

# UI settings
THEME=default
ROWS_PER_PAGE=10

# Logging settings
LOG_FILE=library.log
